#include <Wire.h>
#include <LiquidCrystal_I2C.h>

// --- Pantalla LCD I2C ---
// A4 = SDA, A5 = SCL (conexión I2C automática en Arduino Uno)
LiquidCrystal_I2C lcd(0x27, 16, 2); // Dirección 0x27 (la más común)

// --- Sensor de pulso ---
int sensorPin = A0;
int threshold = 520;
int signal;

unsigned long lastBeat = 0;
bool beatDetected = false;
int bpm = 0;

void setup() {
  Serial.begin(9600);

  lcd.init();
  lcd.backlight();

  // Pantalla de bienvenida
  lcd.setCursor(0, 0);
  lcd.print("Pulso Cardiaco");
  lcd.setCursor(0, 1);
  lcd.print("Iniciando...");
  delay(2000);
  lcd.clear();

  // Pantalla base
  lcd.setCursor(0, 0);
  lcd.print("Frecuencia:");
  lcd.setCursor(0, 1);
  lcd.print("Esperando...");
}

void loop() {
  signal = analogRead(sensorPin);

  if (signal > threshold && !beatDetected) {
    unsigned long currentTime = millis();
    unsigned long interval = currentTime - lastBeat;

    if (lastBeat != 0 && interval > 270 && interval < 2000) {
      bpm = 60000 / interval;

      // Mostrar en Serial
      Serial.print("BPM: ");
      Serial.println(bpm);

      // Mostrar en LCD
      lcd.setCursor(0, 1);
      lcd.print("                "); // Limpiar línea 2
      lcd.setCursor(0, 1);
      lcd.print(bpm);
      lcd.print(" BPM     ");
    }

    lastBeat = currentTime;
    beatDetected = true;
  }

  if (signal < threshold - 10) {
    beatDetected = false;
  }
}
```

